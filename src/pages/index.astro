---
import Base from '../layouts/Base.astro';
import ShelfWall from '../components/ShelfWall.vue';
---

<Base>
  <main class="app">
    <header class="masthead">
      <span class="mark" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="44" height="44">
          <circle cx="24" cy="24" r="21" fill="#c79155" stroke="#6f4c23" stroke-width="2" />
          <circle cx="24" cy="24" r="21" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="1" />
          <circle cx="24" cy="24" r="8" fill="#d4c39c" stroke="rgba(0,0,0,0.3)" stroke-width="1" />
          <circle cx="24" cy="24" r="3.6" fill="#1b1610" />
        </svg>
      </span>
      <div class="title-block">
        <h1>Filament&nbsp;Workshop</h1>
        <p>3D printing filament inventory · sorted by color</p>
      </div>
    </header>

    <ShelfWall client:load />

    <footer class="footswatch">
      <span>fiftyshades.esison.dev</span>
    </footer>
  </main>
</Base>

<style>
  .app {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.6rem 1.2rem 4rem;
  }
  .masthead {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.8rem;
  }
  .mark {
    flex: none;
    filter: drop-shadow(0 4px 5px rgba(0, 0, 0, 0.5));
  }
  .title-block h1 {
    margin: 0;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-ink);
    text-shadow: 0 2px 0 rgba(0, 0, 0, 0.45);
  }
  .title-block p {
    margin: 0.35rem 0 0;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brass);
  }
  .footswatch {
    margin-top: 3rem;
    text-align: center;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-dim);
    opacity: 0.7;
  }
</style>
