# Upstash Redis (REST API) — create a database at https://console.upstash.com/
# and copy the "REST API" URL + token here. Same vars as esison.dev-astro.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Shared secret required to ADD / EDIT / DELETE spools. Viewing is always public.
# Pick something only you know; set it in the Netlify UI for production.
EDIT_PIN=

# Public site URL (used by Astro for canonical/meta). Optional in dev.
PUBLIC_SITE_URL=https://fiftyshades.esison.dev
